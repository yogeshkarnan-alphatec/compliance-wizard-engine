# Copy to .env and fill in. config.py reads these via python-dotenv.

# --- Database (psycopg3 driver) ---
# Matches docker-compose.yml credentials.
DATABASE_URL=postgresql+psycopg://compliance:compliance@localhost:5432/compliance_wizard

# --- OpenAI ---
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o            # optional override; default in config.py
# OPENAI_MAX_TOKENS=2000

# --- Agentic runtime ---
# PIPELINE_MODE=agentic         # agentic (Planner delegates) | classic (fixed sequence)
# LLM_PROVIDER=openai           # openai | anthropic (anthropic needs the `litellm` extra)
# ANTHROPIC_API_KEY=sk-ant-...  # required only when LLM_PROVIDER=anthropic
# ANTHROPIC_MODEL=claude-sonnet-4-6
# AGENT_MAX_TURNS=20
# EXTRACT_MAX_CHARS=70000       # extraction input cap; fit your OpenAI TPM tier (raise if higher)

# --- Observability (LangSmith, optional; native to LangGraph) ---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=compliance-wizard

# --- File store (raw PDFs saved by adapters) ---
FILE_STORE_PATH=./file_store

# --- EUR-Lex / CELLAR ---
# EURLEX_API_BASE=https://eur-lex.europa.eu/

# --- Worker tuning ---
# WORKER_POLL_INTERVAL_SECONDS=5
# WORKER_BATCH_SIZE=1

# --- Review routing ---
# CONFIDENCE_THRESHOLD=0.75
